# ╔══════════════════════════════════════════════════════════════════════╗
# ║  CIVITAS-RAG — Variables d'environnement                            ║
# ║  Copier ce fichier en .env et remplir les valeurs                   ║
# ╚══════════════════════════════════════════════════════════════════════╝
# cp .env.example .env

# ── Application ───────────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_PORT=8000
APP_VERSION=latest
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# ── Qdrant ────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
# QDRANT_API_KEY — ATTENTION : comportement en cascade
# · Vide ou absent    → Qdrant sans auth (recommandé en local)
# · Défini (non-vide) → Qdrant Docker active l'auth et EXIGE cette clé
#   sur chaque requête. Le client Python la transmet automatiquement.
#   Ne définir une valeur qu'en production (Qdrant Cloud).
QDRANT_API_KEY=
# QDRANT_URL=https://xxxx.cloud.qdrant.io   # Qdrant Cloud (override host)
QDRANT_IN_MEMORY=false       # true uniquement pour les tests
QDRANT_MEMORY_LIMIT=2g
QDRANT_SEARCH_THREADS=0      # 0 = auto

# ── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=civitas_knowledge
POSTGRES_USER=civitas
POSTGRES_PASSWORD=civitas_secret   # CHANGER en production !
POSTGRES_MEMORY_LIMIT=1g

# ── Embedding ─────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=sentence-transformers   # sentence-transformers | openai | tfidf-local
# OPENAI_API_KEY=sk-...                    # Si EMBEDDING_PROVIDER=openai

# ── Tracker SQLite ────────────────────────────────────────────────────
CIVITAS_TRACKER_DB=.civitas_ingestion_tracker.db

# ── PgAdmin (optionnel) ───────────────────────────────────────────────
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@civitas.local
PGADMIN_PASSWORD=civitas_admin

# ── Worker ────────────────────────────────────────────────────────────
WORKER_MEMORY_LIMIT=2g
APP_MEMORY_LIMIT=4g

# ── Build (CI/CD) ─────────────────────────────────────────────────────
# BUILD_DATE=
# GIT_COMMIT=
