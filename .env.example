# ═══════════════════════════════════════════════════════════════
#  CIVITAS — Environment Configuration Template
#  Copy to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────
CIVITAS_ENV=development             # development | staging | production
CIVITAS_LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
CIVITAS_LOG_FORMAT=text             # text | json

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=civitas_knowledge
POSTGRES_USER=civitas
POSTGRES_PASSWORD=change_me_in_production

# Connection pool
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_POOL_TIMEOUT=30

# ── pgvector ──────────────────────────────────────────────────
# Vector dimensions must match your embedding model
VECTOR_DIMENSION=1536              # OpenAI text-embedding-3-large = 3072 | small = 1536
VECTOR_SIMILARITY_METRIC=cosine    # cosine | l2 | inner_product

# ── Embedding Models ──────────────────────────────────────────
EMBEDDING_PROVIDER=openai          # openai | huggingface | local
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=100

# ── LLM ───────────────────────────────────────────────────────
LLM_PROVIDER=openai                # openai | anthropic | local
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Ingestion Pipeline ────────────────────────────────────────
INGESTION_CHUNK_SIZE=512
INGESTION_CHUNK_OVERLAP=64
INGESTION_BATCH_SIZE=50
INGESTION_WATCH_DIRS=/data/documents

# ── Indexing ──────────────────────────────────────────────────
INDEX_DEFAULT_TOP_K=10
INDEX_REBUILD_ON_STARTUP=false

# ── GraphRAG ──────────────────────────────────────────────────
GRAPHRAG_ENABLED=true
GRAPHRAG_ENTITY_EXTRACTION_MODEL=gpt-4o-mini
GRAPHRAG_MAX_CLUSTER_SIZE=10
GRAPHRAG_COMMUNITY_REPORTS=true

# ── Quality Control ───────────────────────────────────────────
QUALITY_MIN_SCORE=0.5
QUALITY_AUTO_REJECT_BELOW=0.2
QUALITY_CHECK_ON_INGESTION=true

# ── Governance ────────────────────────────────────────────────
GOVERNANCE_AUDIT_ENABLED=true
GOVERNANCE_RETENTION_DEFAULT_DAYS=365
GOVERNANCE_REQUIRE_APPROVAL=false   # Set true for production

# ── Security ──────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_random_secret_key
API_KEY_SALT=change_me_too
